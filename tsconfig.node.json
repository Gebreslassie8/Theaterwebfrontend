{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ESNext",
    "outDir": "dist-node",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": false,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["vite.config.ts", "**/*.ts"]
}